# ============================================================
# Copy this file to .env and fill in real values.
# Never commit .env — it is in .gitignore.
# In Vercel, set these under Project → Settings → Environment Variables.
# ============================================================

# ------ Required -----------------------------------------------

# Your Google Gemini API key (free tier, no credit card needed).
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ------ Optional: provider swap --------------------------------

# To switch to a different provider (e.g. Groq's OpenAI-compatible free tier),
# update the two constants at the top of api/chat.js instead.
# These env vars can also override them at runtime:
# LLM_MODEL=llama3-70b-8192
# LLM_BASE_URL=https://api.groq.com/openai/v1

# ------ Optional: CORS -----------------------------------------

# Comma-separated list of allowed origins.
# Leave blank to allow all origins (safe for an API that requires a server-side key).
# Example for production: https://krish.consulting,https://www.krish.consulting
ALLOWED_ORIGINS=https://krish.consulting,https://www.krish.consulting

# ------ Optional: lead capture ---------------------------------

# Webhook URL to receive lead data as a JSON POST.
# Works with Google Apps Script, Zapier, Make, Pipedream, Formspree, etc.
# If not set, leads are still logged to Vercel function logs.
# See CHATBOT_README.md for the Google Apps Script setup (recommended, 100% free).
LEAD_WEBHOOK_URL=
